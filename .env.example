# ──────────────────────────────────────────────────────────────────────────
# Regulatory Monitoring Pipeline — environment configuration.
# Copy to .env and adjust. Never commit real secrets — .env is gitignored.
# All settings can also be supplied as real environment variables.
# ──────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────
# Suppress outbound notifications (Slack/email): log instead of sending.
REGMON_DRY_RUN=true

# ── Database ─────────────────────────────────────────────────────────────
# SQLite file (default) or a Postgres URL (e.g. postgresql+asyncpg://...).
REGMON_DB_URL=sqlite:///regmon.db

# ── LLM Provider (OSS-only) ──────────────────────────────────────────────
# One of: mock (default, offline, deterministic), ollama, openai-local
#   ollama:        served via Ollama's OpenAI-compatible endpoint
#   openai-local:  any local OpenAI-compatible server (vLLM, llama.cpp
#                  `server`, LM Studio) reached via REGMON_LLM_BASE_URL
REGMON_LLM_PROVIDER=mock
REGMON_LLM_BASE_URL=http://localhost:11434/v1
REGMON_LLM_MODEL=llama3.1

# ── Embedding Provider (OSS-only) ────────────────────────────────────────
# One of: mock (default, offline, deterministic), sentence-transformers
REGMON_EMBEDDING_PROVIDER=mock
REGMON_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Vector Store ─────────────────────────────────────────────────────────
# One of: memory (default), faiss, chroma
REGMON_VECTOR_STORE=memory

# ── Risk ─────────────────────────────────────────────────────────────────
# 0-100. Risk scores at or above this value trigger the human-in-the-loop
# approval gate; below it is auto-approved (audit-recorded).
REGMON_RISK_THRESHOLD=60

# ── Notifications (optional) ─────────────────────────────────────────────
# Slack incoming webhook URL — leave blank to disable Slack.
REGMON_SLACK_WEBHOOK_URL=
# Email (SMTP) — leave blank to disable email.
REGMON_SMTP_HOST=
REGMON_SMTP_PORT=587
REGMON_SMTP_USERNAME=
REGMON_SMTP_PASSWORD=
REGMON_EMAIL_FROM=regmon-alerts@example.com
REGMON_EMAIL_TO=
